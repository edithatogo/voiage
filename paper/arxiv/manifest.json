{
  "schema_version": "voiage.arxiv-readiness.v1",
  "manuscript_source": "paper/paper.qmd",
  "bibliography": "paper/references.bib",
  "builder": "scripts/build_arxiv_submission.py",
  "required_tools": ["quarto", "pdflatex"],
  "optional_tools": ["arxiv-latex-cleaner", "latexpand", "qpdf", "pdfinfo", "exiftool", "gitleaks"],
  "human_gates": [
    "confirm authors, affiliations, ORCID, funding, and conflicts",
    "select the arXiv category and license",
    "review the final source package and PDF",
    "perform the authenticated arXiv upload"
  ],
  "joss_submission": "out_of_scope_for_this_execution"
}
