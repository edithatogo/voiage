\name{is_voiage_available}
\alias{is_voiage_available}
\title{Check Whether voiage Is Available}
\usage{
is_voiage_available()
}
\value{A logical value indicating whether the Python voiage package can be imported.}
\description{
Checks whether the voiage Python package is available to reticulate.
}
\examples{
\dontrun{
is_voiage_available()
}
}
