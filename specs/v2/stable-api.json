  "methods": {
    "evpi": {
      "status": "stable",
      "implementation": "rust",
      "input_shape": "net_benefit[sample,strategy]",
      "output": "finite-float>=0",
      "missing_values": "reject",
      "errors": [
        "InputError",
        "DimensionMismatchError"
      ]
    },
    "evppi": {
      "status": "stable",
      "implementation": "rust",
      "input_shape": "net_benefit[sample,strategy]+parameters[sample,parameter]",
      "output": "finite-float>=0",
      "missing_values": "reject",
      "errors": [
        "InputError",
        "DimensionMismatchError",
        "BackendNotAvailableError"
      ]
    },
    "evsi": {
      "status": "stable",
      "scientific_maturity": "method-specific",
      "implementation": "rust+python-orchestration",
      "signature": "evsi(model_func, psa_prior, trial_design, population=None, discount_rate=None, time_horizon=None, method=\"two_loop\", n_outer_loops=100, n_inner_loops=1000, metamodel=\"linear\", *, seed=None, trial_simulator=None, posterior_sampler=None)",
      "input_shape": "model+prior[sample,parameter]+trial-design",
      "output": "finite-float",
      "missing_values": "reject",
      "negative_monte_carlo_estimates": "return-untruncated",
      "loop_counts": "positive-non-boolean-integers",
      "errors": [
        "InputError",
        "DimensionMismatchError",
        "BackendNotAvailableError",
        "NumericalError"
      ],
      "built_in_two_loop": {
        "maturity": "fixture-backed",
        "prior": "one-joint-multivariate-normal-fitted-from-finite-psa-rows",
        "coherence": "current-decision-prior-predictive-data-and-posterior-all-use-the-fitted-joint-normal-prior",
        "study_model": "independent-normal-arm-sample-means-with-common-known-outcome-standard-deviation",
        "arm_parameters": "one-unique-normalized-mean_<arm>-parameter-per-arm",
        "fixed_parameters": "sd_outcome-is-finite-strictly-positive-constant-and-excluded-from-stochastic-covariance",
        "posterior": "joint-gaussian-conditioning-updates-all-correlated-stochastic-parameters",
        "outer_loop": "draw-study-data-directly-from-the-fitted-prior-predictive-distribution",
        "inner_loop": "exactly-n_inner_loops-joint-posterior-draws-per-outer-data-set",
        "covariance_failures": "raise-InputError-or-NumericalError-never-raw-linear-algebra-errors"
      },
      "custom_two_loop": {
        "callbacks": "trial_simulator-and-posterior_sampler-required-together",
        "parameter_kind": "keyword-only",
        "trial_simulator": "callable(true_joint_parameters,trial_design,local_rng)->trial_data",
        "posterior_sampler": "callable(prior,trial_data,trial_design,n_draws,local_rng)->exactly-n_draws-joint-ParameterSet",
        "coherence": "callbacks-must-define-one-prior-sampling-likelihood-and-posterior-model"
      },
      "rng": {
        "seed_parameter": "keyword-only-uint64-or-none",
        "seeded": "one-local-generator-reproducible-for-the-declared-dependency-set",
        "unseeded": "fresh-local-generator",
        "global_state": "never-read-or-mutated"
      },
      "compatibility_estimators": {
        "methods": [
          "regression",
          "efficient",
          "efficient_regression",
          "moment_based"
        ],
        "status": "provisional",
        "stable_scientific_contract": false
      }
    },
    "normal_normal_two_arm_evsi": {
      "status": "stable",
      "implementation": "rust",
      "signature": "normal_normal_two_arm_evsi(*, prior_mean, prior_standard_deviation, outcome_standard_deviation, total_sample_size, net_benefit_slope, net_benefit_intercept)",
      "input_shape": "scalar-normal-prior+equal-allocation-two-arm-normal-study+linear-incremental-net-benefit",
      "output": "finite-float>=0",
      "randomness": "none-analytical",
      "study_model": {
        "prior": "incremental-effect-normal",
        "likelihood": "two-independent-normal-arms-with-common-known-outcome-standard-deviation",
        "allocation": "equal",
        "total_sample_size": "positive-even-integer-within-supported-u32-range",
        "net_benefit": "net_benefit_slope*incremental_effect+net_benefit_intercept"
      },
      "errors": [
        "InputError",
        "BackendNotAvailableError",
        "NumericalError"
      ]
    },
    "enbs": {
      "status": "stable",
      "implementation": "rust",
