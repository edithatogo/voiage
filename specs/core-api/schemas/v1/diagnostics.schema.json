{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://voiage.dev/specs/core-api/schemas/v1/diagnostics.schema.json",
  "title": "DiagnosticsV1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "analysis_id",
    "status",
    "warnings",
    "unsupported_capabilities",
    "degraded_paths",
    "approximation_caveats"
  ],
  "properties": {
    "analysis_id": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": ["ok", "degraded", "unsupported", "approximate"]
    },
    "backend": {
      "type": "string",
      "minLength": 1
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["severity", "code", "message"],
        "properties": {
          "severity": {
            "type": "string",
            "enum": ["info", "warning", "critical"]
          },
          "code": {
            "type": "string",
            "minLength": 1
          },
          "message": {
            "type": "string",
            "minLength": 1
          },
          "capability": {
            "type": "string",
            "minLength": 1
          },
          "degraded_path": {
            "type": "string",
            "minLength": 1
          },
          "approximation": {
            "type": "boolean"
          },
          "backend": {
            "type": "string",
            "minLength": 1
          },
          "fallback": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "unsupported_capabilities": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "degraded_paths": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "approximation_caveats": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
