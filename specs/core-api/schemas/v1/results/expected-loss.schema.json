{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://voiage.dev/specs/core-api/schemas/v1/results/expected-loss.schema.json",
  "title": "ExpectedLossV1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "analysis_id",
    "decision_problem_id",
    "analysis_type",
    "strategy_names",
    "expected_net_benefit_by_strategy",
    "expected_opportunity_loss_by_strategy",
    "optimal_strategy_index",
    "minimum_expected_opportunity_loss",
    "sample_count"
  ],
  "properties": {
    "analysis_id": {
      "type": "string",
      "minLength": 1
    },
    "decision_problem_id": {
      "type": "string",
      "minLength": 1
    },
    "analysis_type": {
      "type": "string",
      "const": "expected_loss"
    },
    "strategy_names": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "expected_net_benefit_by_strategy": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "number"
      }
    },
    "expected_opportunity_loss_by_strategy": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "number",
        "minimum": 0
      }
    },
    "optimal_strategy_index": {
      "type": "integer",
      "minimum": 0
    },
    "minimum_expected_opportunity_loss": {
      "type": "number",
      "minimum": 0
    },
    "sample_count": {
      "type": "integer",
      "minimum": 1
    },
    "method": {
      "type": "string",
      "minLength": 1
    },
    "reporting": {
      "type": "object",
      "description": "Extension boundary for reporting and diagnostics."
    }
  }
}
