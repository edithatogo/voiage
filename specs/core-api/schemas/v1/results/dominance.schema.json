{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://voiage.dev/specs/core-api/schemas/v1/results/dominance.schema.json",
  "title": "DominanceV1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "analysis_id",
    "decision_problem_id",
    "analysis_type",
    "strategy_names",
    "costs",
    "effects",
    "frontier_indices",
    "strongly_dominated_indices",
    "extended_dominated_indices",
    "status",
    "incremental_costs",
    "incremental_effects",
    "icers"
  ],
  "properties": {
    "analysis_id": {
      "type": "string",
      "minLength": 1
    },
    "decision_problem_id": {
      "type": "string",
      "minLength": 1
    },
    "analysis_type": {
      "type": "string",
      "const": "dominance"
    },
    "strategy_names": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "costs": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "number"
      }
    },
    "effects": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "number"
      }
    },
    "frontier_indices": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "integer",
        "minimum": 0
      },
      "uniqueItems": true
    },
    "strongly_dominated_indices": {
      "type": "array",
      "items": {
        "type": "integer",
        "minimum": 0
      },
      "uniqueItems": true
    },
    "extended_dominated_indices": {
      "type": "array",
      "items": {
        "type": "integer",
        "minimum": 0
      },
      "uniqueItems": true
    },
    "status": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "string",
        "enum": [
          "frontier",
          "strongly_dominated",
          "extended_dominated"
        ]
      }
    },
    "incremental_costs": {
      "type": "array",
      "items": {
        "type": "number"
      }
    },
    "incremental_effects": {
      "type": "array",
      "items": {
        "type": "number"
      }
    },
    "icers": {
      "type": "array",
      "items": {
        "type": "number"
      }
    },
    "reporting": {
      "type": "object",
      "description": "Extension boundary for reporting and frontier diagnostics."
    }
  }
}
