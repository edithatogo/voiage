{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://voiage.dev/specs/core-api/schemas/v1/results/ceac.schema.json",
  "title": "Cost-Effectiveness Acceptability Curve Result",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "analysis_id",
    "decision_problem_id",
    "analysis_type",
    "strategy_names",
    "willingness_to_pay_values",
    "cost_effectiveness_probabilities"
  ],
  "properties": {
    "analysis_id": {
      "type": "string",
      "minLength": 1
    },
    "decision_problem_id": {
      "type": "string",
      "minLength": 1
    },
    "analysis_type": {
      "const": "ceac"
    },
    "strategy_names": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "willingness_to_pay_values": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "number"
      }
    },
    "cost_effectiveness_probabilities": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "array",
        "minItems": 1,
        "items": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0
        }
      }
    },
    "method": {
      "type": "string",
      "minLength": 1
    },
    "diagnostics": {
      "type": "object"
    }
  }
}
