{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://voiage.dev/specs/core-api/schemas/v2/decision-problem.schema.json",
  "title": "DecisionProblemV2",
  "description": "Backend-neutral decision problem exchanged by every VOIAGE language surface.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "decision_problem_id",
    "title",
    "alternatives",
    "uncertainty",
    "information_actions",
    "objective",
    "perspectives",
    "population",
    "time_horizon",
    "provenance"
  ],
  "properties": {
    "schema_version": {"const": "2.0.0"},
    "decision_problem_id": {"$ref": "#/$defs/identifier"},
    "title": {"type": "string", "minLength": 1},
    "description": {"type": "string"},
    "alternatives": {
      "type": "array",
      "minItems": 2,
      "uniqueItems": true,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["alternative_id", "label"],
        "properties": {
          "alternative_id": {"$ref": "#/$defs/identifier"},
          "label": {"type": "string", "minLength": 1},
          "description": {"type": "string"},
          "is_reference": {"type": "boolean", "default": false}
        }
      }
    },
    "uncertainty": {
      "type": "object",
      "additionalProperties": false,
      "required": ["state_variables", "representation"],
      "properties": {
        "state_variables": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["variable_id", "label", "role"],
            "properties": {
              "variable_id": {"$ref": "#/$defs/identifier"},
              "label": {"type": "string", "minLength": 1},
              "role": {
                "enum": [
                  "parameter",
                  "model-form",
                  "perspective",
                  "data",
                  "implementation",
                  "distribution-shift",
                  "computational"
                ]
              },
              "unit": {"type": "string"},
              "artifact_id": {"$ref": "#/$defs/identifier"}
            }
          }
        },
        "representation": {
          "enum": [
            "posterior-draws",
            "predictive-draws",
            "weighted-scenarios",
            "parametric-model",
            "external-updater"
          ]
        },
        "joint_distribution_artifact_id": {"$ref": "#/$defs/identifier"},
        "preserves_dependence": {"type": "boolean"}
      }
    },
    "information_actions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "information_action_id",
          "label",
          "action_type",
          "reveals",
          "cost"
        ],
        "properties": {
          "information_action_id": {"$ref": "#/$defs/identifier"},
          "label": {"type": "string", "minLength": 1},
          "action_type": {
            "enum": [
              "none",
              "perfect-information",
              "partial-perfect-information",
              "sample-information",
              "measurement",
              "computation",
              "monitoring",
              "expert-review",
              "data-acquisition"
            ]
          },
          "reveals": {
            "type": "array",
            "uniqueItems": true,
            "items": {"$ref": "#/$defs/identifier"}
          },
          "design_artifact_id": {"$ref": "#/$defs/identifier"},
          "updater_artifact_id": {"$ref": "#/$defs/identifier"},
          "cost": {"$ref": "#/$defs/quantity"},
          "latency": {"$ref": "#/$defs/quantity"}
        }
      }
    },
    "objective": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "objective_type",
        "direction",
        "unit",
        "currency_year",
        "artifact_id"
      ],
      "properties": {
        "objective_type": {
          "enum": ["utility", "loss", "net-benefit", "multi-objective"]
        },
        "direction": {"enum": ["maximize", "minimize"]},
        "unit": {"type": "string", "minLength": 1},
        "currency_year": {
          "description": "Price year for monetary objectives; null for non-monetary units.",
          "oneOf": [
            {"type": "integer", "minimum": 1900, "maximum": 2200},
            {"type": "null"}
          ]
        },
        "artifact_id": {"$ref": "#/$defs/identifier"},
        "thresholds": {
          "type": "array",
          "items": {"$ref": "#/$defs/quantity"}
        },
        "attributes": {
          "type": "array",
          "uniqueItems": true,
          "items": {"$ref": "#/$defs/identifier"}
        }
      }
    },
    "perspectives": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["perspective_id", "label", "weight"],
        "properties": {
          "perspective_id": {"$ref": "#/$defs/identifier"},
          "label": {"type": "string", "minLength": 1},
          "weight": {"type": "number", "minimum": 0},
          "objective_artifact_id": {"$ref": "#/$defs/identifier"},
          "population_artifact_id": {"$ref": "#/$defs/identifier"}
        }
      }
    },
    "population": {
      "type": "object",
      "additionalProperties": false,
      "required": ["population_id", "scope"],
      "properties": {
        "population_id": {"$ref": "#/$defs/identifier"},
        "scope": {"type": "string", "minLength": 1},
        "size": {"type": "number", "minimum": 0},
        "subgroup_artifact_id": {"$ref": "#/$defs/identifier"},
        "equity_weight_artifact_id": {"$ref": "#/$defs/identifier"}
      }
    },
    "time_horizon": {
      "type": "object",
      "additionalProperties": false,
      "required": ["value", "unit"],
      "properties": {
        "value": {"type": "number", "exclusiveMinimum": 0},
        "unit": {"enum": ["seconds", "minutes", "hours", "days", "years", "lifetime"]},
        "discount_rate": {"type": "number", "minimum": 0, "maximum": 1}
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["created_at", "creator", "input_artifact_ids"],
      "properties": {
        "created_at": {"type": "string", "format": "date-time"},
        "creator": {"type": "string", "minLength": 1},
        "input_artifact_ids": {
          "type": "array",
          "uniqueItems": true,
          "items": {"$ref": "#/$defs/identifier"}
        },
        "source_uris": {
          "type": "array",
          "uniqueItems": true,
          "items": {"type": "string", "format": "uri"}
        },
        "license": {"type": "string"},
        "content_digest": {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$"
        }
      }
    },
    "extensions": {
      "type": "object",
      "additionalProperties": true,
      "default": {}
    }
  },
  "$defs": {
    "identifier": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"
    },
    "quantity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["value", "unit"],
      "properties": {
        "value": {"type": "number"},
        "unit": {"type": "string", "minLength": 1}
      }
    }
  }
}
