{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://voiage.dev/schemas/normalized-input-bundle/1.0.0",
  "title": "VOIAGE Normalized Input Bundle manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "dataset_id", "tables", "provenance"],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "dataset_id": {"type": "string", "minLength": 1},
    "tables": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/table"}},
    "provenance": {"$ref": "#/$defs/provenance"},
    "resources": {"type": "array", "items": {"$ref": "#/$defs/resource"}},
    "key_references": {"type": "array", "items": {"$ref": "#/$defs/keyReference"}},
    "diagnostics": {"type": "array", "items": {"$ref": "#/$defs/diagnostic"}},
    "bindings": {"type": "array"},
    "binding_profile": {"anyOf": [{"$ref": "#/$defs/bindingProfile"}, {"type": "null"}]},
    "extensions": {"type": "object"}
  },
  "$defs": {
    "identifier": {"type": "string", "minLength": 1},
    "digest": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "field": {
      "type": "object",
      "additionalProperties": false,
      "required": ["field_id", "dtype", "unit", "nullable", "description", "semantic_type"],
      "properties": {
        "field_id": {"$ref": "#/$defs/identifier"},
        "dtype": {"$ref": "#/$defs/identifier"},
        "unit": {"type": ["string", "null"]},
        "nullable": {"type": "boolean"},
        "description": {"type": ["string", "null"]},
        "semantic_type": {"type": ["string", "null"]}
      }
    },
    "table": {
      "type": "object",
      "additionalProperties": false,
      "required": ["table_id", "fields", "primary_key"],
      "properties": {
        "table_id": {"$ref": "#/$defs/identifier"},
        "fields": {"type": "array", "items": {"$ref": "#/$defs/field"}},
        "primary_key": {"type": "array", "items": {"$ref": "#/$defs/identifier"}}
      }
    },
    "provenance": {"type": "object"},
    "resource": {
      "type": "object",
      "additionalProperties": false,
      "required": ["resource_id", "uri", "sha256", "media_type", "byte_size", "retrieved_at"],
      "properties": {
        "resource_id": {"$ref": "#/$defs/identifier"},
        "uri": {"type": "string"},
        "sha256": {"$ref": "#/$defs/digest"},
        "media_type": {"type": ["string", "null"]},
        "byte_size": {"type": ["integer", "null"], "minimum": 0},
        "retrieved_at": {"type": ["string", "null"]}
      }
    },
    "keyReference": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_table_id", "source_field_ids", "target_table_id", "target_field_ids"],
      "properties": {
        "source_table_id": {"$ref": "#/$defs/identifier"},
        "source_field_ids": {"type": "array", "items": {"$ref": "#/$defs/identifier"}},
        "target_table_id": {"$ref": "#/$defs/identifier"},
        "target_field_ids": {"type": "array", "items": {"$ref": "#/$defs/identifier"}}
      }
    },
    "diagnostic": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "severity", "message", "table_id", "field_id"],
      "properties": {
        "code": {"$ref": "#/$defs/identifier"},
        "severity": {"enum": ["info", "warning", "error"]},
        "message": {"type": "string"},
        "table_id": {"type": ["string", "null"]},
        "field_id": {"type": ["string", "null"]}
      }
    },
    "bindingProfile": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema_version", "bindings"],
      "properties": {
        "schema_version": {"const": "1.0.0"},
        "bindings": {"type": "array"}
      }
    }
  }
}
