{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://voiage.dev/specs/frontier/fixtures/manifest.schema.json",
  "title": "FrontierFixtureRegistryV1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "status",
    "families"
  ],
  "properties": {
    "version": {
      "type": "string",
      "const": "v1"
    },
    "status": {
      "type": "string",
      "const": "registry"
    },
    "families": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "path",
          "method_maturity"
        ],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "path": {
            "type": "string",
            "minLength": 1
          },
          "method_maturity": {
            "type": "string",
            "const": "experimental"
          }
        }
      }
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
