{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://voiage.dev/specs/frontier/threshold/v1/schemas/value-of-threshold-result.schema.json",
  "title": "ValueOfThresholdResultV1Planned",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "analysis_id",
    "decision_problem_id",
    "analysis_type",
    "method_maturity",
    "value",
    "threshold_profile_ids",
    "strategy_names",
    "expected_net_benefits",
    "optimal_strategy_by_threshold_profile",
    "threshold_crossing_probability_matrix",
    "decision_reversal_matrix",
    "robust_strategy",
    "tipping_point_strategy",
    "pareto_strategies",
    "reference_threshold_profile",
    "reporting"
  ],
  "properties": {
    "analysis_id": {
      "type": "string",
      "minLength": 1
    },
    "decision_problem_id": {
      "type": "string",
      "minLength": 1
    },
    "analysis_type": {
      "type": "string",
      "const": "value_of_threshold_information"
    },
    "method_maturity": {
      "type": "string",
      "const": "planned"
    },
    "value": {
      "type": "number",
      "minimum": 0
    },
    "threshold_profile_ids": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "strategy_names": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "expected_net_benefits": {
      "type": "array",
      "items": {
        "type": "array",
        "items": {
          "type": "number"
        }
      }
    },
    "optimal_strategy_by_threshold_profile": {
      "type": "object",
      "additionalProperties": {
        "type": "string",
        "minLength": 1
      }
    },
    "threshold_crossing_probability_matrix": {
      "type": "array",
      "items": {
        "type": "array",
        "items": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      }
    },
    "decision_reversal_matrix": {
      "type": "array",
      "items": {
        "type": "array",
        "items": {
          "type": "number",
          "minimum": 0
        }
      }
    },
    "robust_strategy": {
      "type": "string",
      "minLength": 1
    },
    "tipping_point_strategy": {
      "type": "string",
      "minLength": 1
    },
    "pareto_strategies": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "reference_threshold_profile": {
      "type": "string",
      "minLength": 1
    },
    "reporting": {
      "type": "object"
    },
    "diagnostics": {
      "type": "object"
    }
  }
}
