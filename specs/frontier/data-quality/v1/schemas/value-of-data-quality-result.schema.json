{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://voiage.dev/specs/frontier/data-quality/v1/schemas/value-of-data-quality-result.schema.json",
  "title": "ValueOfDataQualityResultV1Planned",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "analysis_id",
    "decision_problem_id",
    "analysis_type",
    "method_maturity",
    "value",
    "acquisition_cost_value",
    "privacy_value",
    "measurement_error_value",
    "linkage_value",
    "data_quality_profile_ids",
    "strategy_names",
    "expected_net_benefits",
    "optimal_strategy_by_data_quality_profile",
    "acquisition_cost_matrix",
    "privacy_constraint_matrix",
    "measurement_error_matrix",
    "linkage_weight_matrix",
    "robust_strategy",
    "pareto_strategies",
    "reference_data_quality_profile",
    "reporting"
  ],
  "properties": {
    "analysis_id": {
      "type": "string",
      "minLength": 1
    },
    "decision_problem_id": {
      "type": "string",
      "minLength": 1
    },
    "analysis_type": {
      "type": "string",
      "const": "value_of_data_quality_privacy_linkage"
    },
    "method_maturity": {
      "type": "string",
      "const": "planned"
    },
    "value": {
      "type": "number",
      "minimum": 0
    },
    "acquisition_cost_value": {
      "type": "number",
      "minimum": 0
    },
    "privacy_value": {
      "type": "number",
      "minimum": 0
    },
    "measurement_error_value": {
      "type": "number",
      "minimum": 0
    },
    "linkage_value": {
      "type": "number",
      "minimum": 0
    },
    "data_quality_profile_ids": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "strategy_names": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "expected_net_benefits": {
      "type": "array",
      "items": {
        "type": "array",
        "items": {
          "type": "number"
        }
      }
    },
    "optimal_strategy_by_data_quality_profile": {
      "type": "object",
      "additionalProperties": {
        "type": "string",
        "minLength": 1
      }
    },
    "acquisition_cost_matrix": {
      "type": "array",
      "items": {
        "type": "array",
        "items": {
          "type": "number",
          "minimum": 0
        }
      }
    },
    "privacy_constraint_matrix": {
      "type": "array",
      "items": {
        "type": "array",
        "items": {
          "type": "number",
          "minimum": 0
        }
      }
    },
    "measurement_error_matrix": {
      "type": "array",
      "items": {
        "type": "array",
        "items": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      }
    },
    "linkage_weight_matrix": {
      "type": "array",
      "items": {
        "type": "array",
        "items": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      }
    },
    "consensus_strategy": {
      "type": "string",
      "minLength": 1
    },
    "robust_strategy": {
      "type": "string",
      "minLength": 1
    },
    "pareto_strategies": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "reference_data_quality_profile": {
      "type": "string",
      "minLength": 1
    },
    "reporting": {
      "type": "object"
    },
    "diagnostics": {
      "type": "object"
    }
  }
}
