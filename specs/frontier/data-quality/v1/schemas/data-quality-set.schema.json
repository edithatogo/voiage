{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://voiage.dev/specs/frontier/data-quality/v1/schemas/data-quality-set.schema.json",
  "title": "DataQualitySetV1Planned",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "analysis_type",
    "data_quality_profile_ids",
    "strategy_names",
    "acquisition_costs",
    "privacy_constraints",
    "linkage_weights"
  ],
  "properties": {
    "analysis_type": {
      "type": "string",
      "const": "value_of_data_quality_privacy_linkage"
    },
    "data_quality_profile_ids": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "strategy_names": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "acquisition_costs": {
      "type": "array",
      "items": {
        "type": "array",
        "items": {
          "type": "number",
          "minimum": 0
        }
      }
    },
    "privacy_constraints": {
      "type": "array",
      "items": {
        "type": "array",
        "items": {
          "type": "number",
          "minimum": 0
        }
      }
    },
    "linkage_weights": {
      "type": "array",
      "items": {
        "type": "array",
        "items": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      }
    },
    "measurement_error_rates": {
      "type": "array",
      "items": {
        "type": "array",
        "items": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      }
    },
    "source_quality_labels": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "operational_context": {
      "type": "string",
      "minLength": 1
    }
  }
}
