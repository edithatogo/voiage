{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://voiage.dev/specs/frontier/monitoring-surveillance/v1/schemas/value-of-monitoring-surveillance-result.schema.json",
  "title": "ValueOfMonitoringSurveillanceResultV1FixtureBacked",
  "type": "object",
  "additionalProperties": false,
  "required": ["analysis_id", "decision_problem_id", "analysis_type", "method_maturity", "value", "monitoring_value", "signal_detection_value", "decision_revision_value", "stopping_value", "strategy_names", "expected_net_benefits", "optimal_strategy_by_period", "monitoring_cost_matrix", "detection_delay_matrix", "false_signal_rate_matrix", "decision_revision_matrix", "surveillance_frequency", "stopping_period", "reporting"],
  "properties": {
    "analysis_id": {"type": "string", "minLength": 1},
    "decision_problem_id": {"type": "string", "minLength": 1},
    "analysis_type": {"const": "value_of_monitoring_surveillance"},
    "method_maturity": {"const": "fixture-backed"},
    "value": {"type": "number", "minimum": 0},
    "monitoring_value": {"type": "number", "minimum": 0},
    "signal_detection_value": {"type": "number", "minimum": 0},
    "decision_revision_value": {"type": "number", "minimum": 0},
    "stopping_value": {"type": "number", "minimum": 0},
    "strategy_names": {"type": "array", "minItems": 1, "items": {"type": "string"}},
    "expected_net_benefits": {"type": "array"},
    "optimal_strategy_by_period": {"type": "object"},
    "monitoring_cost_matrix": {"type": "array"},
    "detection_delay_matrix": {"type": "array"},
    "false_signal_rate_matrix": {"type": "array"},
    "decision_revision_matrix": {"type": "array"},
    "surveillance_frequency": {"type": "number", "exclusiveMinimum": 0},
    "stopping_period": {"type": ["integer", "null"], "minimum": 0},
    "reporting": {"type": "object"},
    "diagnostics": {"type": "object"}
  }
}
