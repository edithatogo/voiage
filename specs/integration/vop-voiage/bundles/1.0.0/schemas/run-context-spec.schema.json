{
  "$defs": {
    "MetadataStatus": {
      "description": "Epistemic status of imported unit or provenance metadata.",
      "enum": [
        "known",
        "provisional",
        "unknown"
      ],
      "title": "MetadataStatus",
      "type": "string"
    },
    "NonFinitePolicy": {
      "description": "Permitted response to non-finite numerical output.",
      "enum": [
        "raise",
        "report"
      ],
      "title": "NonFinitePolicy",
      "type": "string"
    },
    "NumericalPolicySpec": {
      "additionalProperties": false,
      "description": "Explicit reproducibility and convergence policy for a calculation.",
      "properties": {
        "absolute_tolerance": {
          "default": 1e-09,
          "exclusiveMinimum": 0.0,
          "title": "Absolute Tolerance",
          "type": "number"
        },
        "deterministic": {
          "default": true,
          "title": "Deterministic",
          "type": "boolean"
        },
        "max_iterations": {
          "default": 10000,
          "exclusiveMinimum": 0,
          "title": "Max Iterations",
          "type": "integer"
        },
        "non_finite_policy": {
          "$ref": "#/$defs/NonFinitePolicy",
          "default": "raise"
        },
        "relative_tolerance": {
          "default": 1e-09,
          "exclusiveMinimum": 0.0,
          "title": "Relative Tolerance",
          "type": "number"
        }
      },
      "title": "NumericalPolicySpec",
      "type": "object"
    },
    "ProvenanceSpec": {
      "additionalProperties": false,
      "description": "Traceable identity for an input, source, or generated contract.",
      "properties": {
        "content_sha256": {
          "anyOf": [
            {
              "pattern": "^[0-9a-f]{64}$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Content Sha256"
        },
        "metadata_status": {
          "$ref": "#/$defs/MetadataStatus",
          "default": "known"
        },
        "observed_at_utc": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Observed At Utc"
        },
        "source_id": {
          "minLength": 1,
          "title": "Source Id",
          "type": "string"
        },
        "source_version": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Source Version"
        }
      },
      "required": [
        "source_id"
      ],
      "title": "ProvenanceSpec",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "description": "Portable execution context shared by deterministic analysis kernels.",
  "properties": {
    "case_id": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Case Id"
    },
    "created_at_utc": {
      "anyOf": [
        {
          "format": "date-time",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Created At Utc"
    },
    "numerical_policy": {
      "$ref": "#/$defs/NumericalPolicySpec",
      "default": {
        "absolute_tolerance": 1e-09,
        "deterministic": true,
        "max_iterations": 10000,
        "non_finite_policy": "raise",
        "relative_tolerance": 1e-09
      }
    },
    "provenance": {
      "default": [],
      "items": {
        "$ref": "#/$defs/ProvenanceSpec"
      },
      "title": "Provenance",
      "type": "array"
    },
    "run_id": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Run Id"
    },
    "seed": {
      "anyOf": [
        {
          "type": "integer"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Seed"
    },
    "software_version": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Software Version"
    }
  },
  "title": "RunContextSpec",
  "type": "object"
}
