{
  "$defs": {
    "MetadataStatus": {
      "description": "Epistemic status of imported unit or provenance metadata.",
      "enum": [
        "known",
        "provisional",
        "unknown"
      ],
      "title": "MetadataStatus",
      "type": "string"
    },
    "NonFinitePolicy": {
      "description": "Permitted response to non-finite numerical output.",
      "enum": [
        "raise",
        "report"
      ],
      "title": "NonFinitePolicy",
      "type": "string"
    },
    "NumericalPolicySpec": {
      "additionalProperties": false,
      "description": "Explicit reproducibility and convergence policy for a calculation.",
      "properties": {
        "absolute_tolerance": {
          "default": 1e-09,
          "exclusiveMinimum": 0.0,
          "title": "Absolute Tolerance",
          "type": "number"
        },
        "deterministic": {
          "default": true,
          "title": "Deterministic",
          "type": "boolean"
        },
        "max_iterations": {
          "default": 10000,
          "exclusiveMinimum": 0,
          "title": "Max Iterations",
          "type": "integer"
        },
        "non_finite_policy": {
          "$ref": "#/$defs/NonFinitePolicy",
          "default": "raise"
        },
        "relative_tolerance": {
          "default": 1e-09,
          "exclusiveMinimum": 0.0,
          "title": "Relative Tolerance",
          "type": "number"
        }
      },
      "title": "NumericalPolicySpec",
      "type": "object"
    },
    "ParameterSpec": {
      "additionalProperties": false,
      "description": "Named scalar parameter with unit, dimensions, and provenance.",
      "properties": {
        "dimensions": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "Dimensions",
          "type": "array"
        },
        "name": {
          "minLength": 1,
          "title": "Name",
          "type": "string"
        },
        "provenance": {
          "$ref": "#/$defs/ProvenanceSpec"
        },
        "unit": {
          "$ref": "#/$defs/UnitSpec"
        },
        "value": {
          "title": "Value",
          "type": "number"
        }
      },
      "required": [
        "name",
        "value",
        "unit",
        "provenance"
      ],
      "title": "ParameterSpec",
      "type": "object"
    },
    "ProvenanceSpec": {
      "additionalProperties": false,
      "description": "Traceable identity for an input, source, or generated contract.",
      "properties": {
        "content_sha256": {
          "anyOf": [
            {
              "pattern": "^[0-9a-f]{64}$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Content Sha256"
        },
        "metadata_status": {
          "$ref": "#/$defs/MetadataStatus",
          "default": "known"
        },
        "observed_at_utc": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Observed At Utc"
        },
        "source_id": {
          "minLength": 1,
          "title": "Source Id",
          "type": "string"
        },
        "source_version": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Source Version"
        }
      },
      "required": [
        "source_id"
      ],
      "title": "ProvenanceSpec",
      "type": "object"
    },
    "UnitDimension": {
      "description": "Physical or decision-model dimension represented by a unit.",
      "enum": [
        "currency",
        "time",
        "health",
        "probability",
        "count",
        "dimensionless"
      ],
      "title": "UnitDimension",
      "type": "string"
    },
    "UnitSpec": {
      "additionalProperties": false,
      "description": "Machine-readable unit identity, including currency price year.",
      "properties": {
        "currency_code": {
          "anyOf": [
            {
              "pattern": "^[A-Z]{3}$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Currency Code"
        },
        "currency_year": {
          "anyOf": [
            {
              "maximum": 2200,
              "minimum": 1900,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Currency Year"
        },
        "dimension": {
          "$ref": "#/$defs/UnitDimension"
        },
        "metadata_status": {
          "$ref": "#/$defs/MetadataStatus",
          "default": "known"
        },
        "symbol": {
          "minLength": 1,
          "title": "Symbol",
          "type": "string"
        }
      },
      "required": [
        "symbol",
        "dimension"
      ],
      "title": "UnitSpec",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "description": "Generic analysis identity and its typed scalar inputs.",
  "properties": {
    "analysis_type": {
      "minLength": 1,
      "title": "Analysis Type",
      "type": "string"
    },
    "contract_version": {
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$",
      "title": "Contract Version",
      "type": "string"
    },
    "numerical_policy": {
      "$ref": "#/$defs/NumericalPolicySpec",
      "default": {
        "absolute_tolerance": 1e-09,
        "deterministic": true,
        "max_iterations": 10000,
        "non_finite_policy": "raise",
        "relative_tolerance": 1e-09
      }
    },
    "parameters": {
      "default": [],
      "items": {
        "$ref": "#/$defs/ParameterSpec"
      },
      "title": "Parameters",
      "type": "array"
    }
  },
  "required": [
    "analysis_type",
    "contract_version"
  ],
  "title": "AnalysisSpec",
  "type": "object"
}
