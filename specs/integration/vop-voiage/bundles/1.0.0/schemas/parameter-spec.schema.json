{
  "$defs": {
    "MetadataStatus": {
      "description": "Epistemic status of imported unit or provenance metadata.",
      "enum": [
        "known",
        "provisional",
        "unknown"
      ],
      "title": "MetadataStatus",
      "type": "string"
    },
    "ProvenanceSpec": {
      "additionalProperties": false,
      "description": "Traceable identity for an input, source, or generated contract.",
      "properties": {
        "content_sha256": {
          "anyOf": [
            {
              "pattern": "^[0-9a-f]{64}$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Content Sha256"
        },
        "metadata_status": {
          "$ref": "#/$defs/MetadataStatus",
          "default": "known"
        },
        "observed_at_utc": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Observed At Utc"
        },
        "source_id": {
          "minLength": 1,
          "title": "Source Id",
          "type": "string"
        },
        "source_version": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Source Version"
        }
      },
      "required": [
        "source_id"
      ],
      "title": "ProvenanceSpec",
      "type": "object"
    },
    "UnitDimension": {
      "description": "Physical or decision-model dimension represented by a unit.",
      "enum": [
        "currency",
        "time",
        "health",
        "probability",
        "count",
        "dimensionless"
      ],
      "title": "UnitDimension",
      "type": "string"
    },
    "UnitSpec": {
      "additionalProperties": false,
      "description": "Machine-readable unit identity, including currency price year.",
      "properties": {
        "currency_code": {
          "anyOf": [
            {
              "pattern": "^[A-Z]{3}$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Currency Code"
        },
        "currency_year": {
          "anyOf": [
            {
              "maximum": 2200,
              "minimum": 1900,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Currency Year"
        },
        "dimension": {
          "$ref": "#/$defs/UnitDimension"
        },
        "metadata_status": {
          "$ref": "#/$defs/MetadataStatus",
          "default": "known"
        },
        "symbol": {
          "minLength": 1,
          "title": "Symbol",
          "type": "string"
        }
      },
      "required": [
        "symbol",
        "dimension"
      ],
      "title": "UnitSpec",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "description": "Named scalar parameter with unit, dimensions, and provenance.",
  "properties": {
    "dimensions": {
      "default": [],
      "items": {
        "type": "string"
      },
      "title": "Dimensions",
      "type": "array"
    },
    "name": {
      "minLength": 1,
      "title": "Name",
      "type": "string"
    },
    "provenance": {
      "$ref": "#/$defs/ProvenanceSpec"
    },
    "unit": {
      "$ref": "#/$defs/UnitSpec"
    },
    "value": {
      "title": "Value",
      "type": "number"
    }
  },
  "required": [
    "name",
    "value",
    "unit",
    "provenance"
  ],
  "title": "ParameterSpec",
  "type": "object"
}
