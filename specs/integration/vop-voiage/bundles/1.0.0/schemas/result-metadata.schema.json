{
  "$defs": {
    "ArrowSchemaIdentity": {
      "additionalProperties": false,
      "description": "Stable identity for the Arrow projection of a result.",
      "properties": {
        "schema_fingerprint": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Schema Fingerprint",
          "type": "string"
        },
        "schema_id": {
          "minLength": 1,
          "title": "Schema Id",
          "type": "string"
        },
        "schema_version": {
          "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$",
          "title": "Schema Version",
          "type": "string"
        }
      },
      "required": [
        "schema_id",
        "schema_version",
        "schema_fingerprint"
      ],
      "title": "ArrowSchemaIdentity",
      "type": "object"
    },
    "DiagnosticSeverity": {
      "description": "Machine-readable severity for calculation diagnostics.",
      "enum": [
        "info",
        "warning",
        "error"
      ],
      "title": "DiagnosticSeverity",
      "type": "string"
    },
    "MetadataStatus": {
      "description": "Epistemic status of imported unit or provenance metadata.",
      "enum": [
        "known",
        "provisional",
        "unknown"
      ],
      "title": "MetadataStatus",
      "type": "string"
    },
    "ProvenanceSpec": {
      "additionalProperties": false,
      "description": "Traceable identity for an input, source, or generated contract.",
      "properties": {
        "content_sha256": {
          "anyOf": [
            {
              "pattern": "^[0-9a-f]{64}$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Content Sha256"
        },
        "metadata_status": {
          "$ref": "#/$defs/MetadataStatus",
          "default": "known"
        },
        "observed_at_utc": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Observed At Utc"
        },
        "source_id": {
          "minLength": 1,
          "title": "Source Id",
          "type": "string"
        },
        "source_version": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Source Version"
        }
      },
      "required": [
        "source_id"
      ],
      "title": "ProvenanceSpec",
      "type": "object"
    },
    "ResultDiagnostic": {
      "additionalProperties": false,
      "description": "Structured calculation diagnostic without free-form mappings.",
      "properties": {
        "code": {
          "minLength": 1,
          "title": "Code",
          "type": "string"
        },
        "message": {
          "minLength": 1,
          "title": "Message",
          "type": "string"
        },
        "severity": {
          "$ref": "#/$defs/DiagnosticSeverity"
        }
      },
      "required": [
        "code",
        "severity",
        "message"
      ],
      "title": "ResultDiagnostic",
      "type": "object"
    },
    "ResultMaturity": {
      "description": "Governed stability level of a result contract.",
      "enum": [
        "experimental",
        "provisional",
        "stable"
      ],
      "title": "ResultMaturity",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "description": "Version, maturity, diagnostics, provenance, and Arrow identity.",
  "properties": {
    "arrow_schema": {
      "$ref": "#/$defs/ArrowSchemaIdentity"
    },
    "contract_version": {
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$",
      "title": "Contract Version",
      "type": "string"
    },
    "diagnostics": {
      "default": [],
      "items": {
        "$ref": "#/$defs/ResultDiagnostic"
      },
      "title": "Diagnostics",
      "type": "array"
    },
    "maturity": {
      "$ref": "#/$defs/ResultMaturity"
    },
    "provenance": {
      "default": [],
      "items": {
        "$ref": "#/$defs/ProvenanceSpec"
      },
      "title": "Provenance",
      "type": "array"
    }
  },
  "required": [
    "contract_version",
    "maturity",
    "arrow_schema"
  ],
  "title": "ResultMetadata",
  "type": "object"
}
