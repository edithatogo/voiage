{"assumptions":["Costs and health outcomes accrue at the start of each cycle.","Expected values use an equally weighted arithmetic mean over draws.","A treatment is cost effective only when incremental NMB is greater than zero.","Population EVPI is undiscounted per-person EVPI multiplied by population size.","Directional EVoP chooses by expected NMB under one perspective and evaluates regret under another."],"binding":"language_runtime_neutral","cases":[{"calculation":"discounted_markov_cost_effectiveness","case_id":"cea_one_state_two_cycle","derivation":["With identity transition and discount rate 0, each two-cycle total is 2*per_cycle_value.","Health incremental cost = 2*(130-100) = 60 NZD.","Incremental QALY = 2*(1.01-1.00) = 0.02 QALY.","Health ICER = 60/0.02 = 3000 NZD/QALY.","Health incremental NMB = 5000*0.02-60 = 40 NZD.","Societal per-cycle costs are health + additional societal + human-capital productivity.","Societal incremental cost = 2*((130+5+10)-(100+20+30)) = -10 NZD.","Societal ICER = -10/0.02 = -500 NZD/QALY; incremental NMB = 5000*0.02-(-10) = 110 NZD."],"expected":{"health_system":{"cost_new_treatment":260.0,"cost_standard_care":200.0,"icer_status":"finite","icer_value":3000.0,"incremental_cost":60.0,"incremental_nmb":40.0,"incremental_qalys":0.02,"is_cost_effective":true,"qalys_new_treatment":2.02,"qalys_standard_care":2.0},"societal_human_capital":{"cost_new_treatment":290.0,"cost_standard_care":300.0,"icer_status":"finite","icer_value":-500.0,"incremental_cost":-10.0,"incremental_nmb":110.0,"incremental_qalys":0.02,"is_cost_effective":true,"qalys_new_treatment":2.02,"qalys_standard_care":2.0}},"inputs":{"costs":{"health_system":{"new_treatment":[130.0],"standard_care":[100.0]},"societal":{"new_treatment":[5.0],"standard_care":[20.0]}},"cycles":2,"discount_rate":0.0,"initial_population":[1.0],"productivity_costs":{"human_capital":{"new_treatment":[10.0],"standard_care":[30.0]}},"qalys":{"new_treatment":[1.01],"standard_care":[1.0]},"states":["alive"],"transition_matrices":{"new_treatment":[[1.0]],"standard_care":[[1.0]]},"wtp_threshold":5000.0}},{"calculation":"expected_value_of_perfect_information","case_id":"evpi_two_draw_crossing","derivation":["Standard-care NMB is [0,0] NZD and new-treatment NMB is [100,-100] NZD.","Perfect-information expected NMB = mean([100,0]) = 50 NZD.","Current-information NMB = max(mean([0,0]),mean([100,-100])) = 0 NZD.","EVPI per person = 50-0 = 50 NZD; population EVPI = 50*1000 = 50000 NZD."],"expected":{"evpi_per_person":50.0,"population_evpi":50000.0},"inputs":{"draws":[{"cost_nt":0.0,"cost_sc":0.0,"qaly_nt":1.0,"qaly_sc":0.0},{"cost_nt":100.0,"cost_sc":0.0,"qaly_nt":0.0,"qaly_sc":0.0}],"target_population_size":1000,"wtp_threshold":100.0}},{"calculation":"directional_expected_value_of_perspective","case_id":"directional_evop_opposed_choices","derivation":["Expected NMB under health_system selects A (10 versus 0).","Evaluating A instead of societal-optimal B under societal loses 100 NZD per draw.","The reverse direction selects B then loses 10 NZD per draw under health_system.","The draw-level optimal strategies disagree on both draws, so discordance is 1."],"expected":{"discordance_probability":1.0,"health_system_to_societal":100.0,"societal_to_health_system":10.0},"inputs":{"axis_order":["draw","strategy","perspective"],"decision_rule":"expected_value","net_benefit":[[[10.0,0.0],[0.0,100.0]],[[10.0,0.0],[0.0,100.0]]],"perspectives":["health_system","societal"],"selection_tie_policy":"first","strategies":["A","B"]}}],"comparison":{"absolute_tolerance":1e-12,"boolean_comparison":"exact","relative_tolerance":1e-12,"rule":"abs(actual-expected) <= atol + rtol*abs(expected)","string_comparison":"exact_utf8"},"method_contract_version":"1.1.0","provenance":{"derivation_date":"2026-07-20","derivation_method":"hand_calculated_closed_form","implementation_dependency":"none","review_status":"producer_authored_pending_external_replication","source_id":"manual-algebra:vop-voiage-reference-v1"},"reference_id":"vop-voiage-analytical-reference","reference_version":"1.0.0","schema_version":"1.0.0","units":{"cost":{"currency_code":"NZD","currency_year":2026,"dimension":"currency","symbol":"NZD"},"health":{"dimension":"health","symbol":"QALY"},"population":{"dimension":"count","symbol":"person"},"wtp":{"dimension":"currency_per_health","symbol":"NZD/QALY"}}}
