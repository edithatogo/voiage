{
  "$schema": "../compatibility-contract.schema.json",
  "contract_schema_version": "1.0.0",
  "contract_version": "1.0.0",
  "method_contract_version": "1.1.0",
  "owner": {
    "repository": "edithatogo/vop_poc_nz",
    "track": "C09",
    "path": "contracts/vop-voiage/compatibility/v1/contract.json"
  },
  "consumers": ["vop_poc_nz", "voiage"],
  "runtime": {"python": ">=3.14", "free_threaded": "observational"},
  "shared_dependencies": {
    "numpy": ">=2.5.1,<3",
    "pandas": ">=3.0.3,<4",
    "pyarrow": ">=25.0.0,<26",
    "polars": ">=1.42.1,<2"
  },
  "interchange": {
    "canonical_format": "parquet",
    "parquet_version": "2.6",
    "compression": "zstd",
    "ipc_suffix": ".arrow",
    "c_stream_protocol": "__arrow_c_stream__",
    "fingerprint": {
      "algorithm": "sha256",
      "input": "canonical-json-ordered-logical-fields-v1",
      "object_keys": "sorted",
      "field_order": "preserved",
      "include_metadata": false
    }
  },
  "profiles": {
    "net_benefit_records": {"producer": "vop_poc_nz", "schema_version": "1.0.0"},
    "directional_regret": {"producer": "voiage", "schema_version": "1.0.0"}
  },
  "capabilities": {
    "polars_cpu": {"maturity": "stable", "required": true},
    "python_free_threading": {"maturity": "observational", "required": false},
    "polars_gpu": {"maturity": "experimental", "required": false, "platforms": ["linux", "wsl2"], "fallback_must_be_reported": true}
  },
  "validation": {"float_rtol": 1e-12, "float_atol": 1e-12, "previous_major_readability": 1}
}
