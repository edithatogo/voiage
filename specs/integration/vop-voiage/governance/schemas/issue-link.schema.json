{
  "$defs": {
    "Relation": {
      "additionalProperties": false,
      "description": "Typed edge between governance records.",
      "properties": {
        "relation": {
          "enum": [
            "informs",
            "depends_on",
            "blocks",
            "mitigates",
            "mitigated_by",
            "resolved_by",
            "supersedes",
            "implements",
            "supports",
            "challenges"
          ],
          "title": "Relation",
          "type": "string"
        },
        "target_id": {
          "pattern": "^(CON|ASM|RSK|DEC|EVR|ISL)-(VOP|VOI|SHR)-[0-9]{4}$",
          "title": "Target Id",
          "type": "string"
        }
      },
      "required": [
        "relation",
        "target_id"
      ],
      "title": "Relation",
      "type": "object"
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Desired GitHub issue and Project projection for governance records.",
  "properties": {
    "close_requires_approval": {
      "const": true,
      "default": true,
      "title": "Close Requires Approval",
      "type": "boolean"
    },
    "created_at": {
      "anyOf": [
        {
          "format": "date-time",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Created At"
    },
    "desired_state": {
      "default": "open",
      "enum": [
        "open",
        "closed"
      ],
      "title": "Desired State",
      "type": "string"
    },
    "evidence_reference_ids": {
      "default": [],
      "items": {
        "type": "string"
      },
      "title": "Evidence Reference Ids",
      "type": "array"
    },
    "gate": {
      "default": "local",
      "enum": [
        "none",
        "local",
        "external",
        "human",
        "credential",
        "hardware",
        "publication"
      ],
      "title": "Gate",
      "type": "string"
    },
    "github_repository": {
      "pattern": "^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$",
      "title": "Github Repository",
      "type": "string"
    },
    "id": {
      "title": "Id",
      "type": "string"
    },
    "issue_link_ids": {
      "default": [],
      "items": {
        "type": "string"
      },
      "title": "Issue Link Ids",
      "type": "array"
    },
    "issue_number": {
      "anyOf": [
        {
          "minimum": 1,
          "type": "integer"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Issue Number"
    },
    "managed_labels": {
      "default": [],
      "items": {
        "type": "string"
      },
      "title": "Managed Labels",
      "type": "array"
    },
    "moscow": {
      "default": "should",
      "enum": [
        "must",
        "should",
        "could",
        "wont_now"
      ],
      "title": "Moscow",
      "type": "string"
    },
    "owner_role": {
      "default": "maintainer",
      "title": "Owner Role",
      "type": "string"
    },
    "preserve_human_content": {
      "const": true,
      "default": true,
      "title": "Preserve Human Content",
      "type": "boolean"
    },
    "priority": {
      "default": "P2",
      "enum": [
        "P0",
        "P1",
        "P2",
        "P3"
      ],
      "title": "Priority",
      "type": "string"
    },
    "project_number": {
      "anyOf": [
        {
          "minimum": 1,
          "type": "integer"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Project Number"
    },
    "record_type": {
      "const": "issue_link",
      "default": "issue_link",
      "title": "Record Type",
      "type": "string"
    },
    "record_version": {
      "default": 1,
      "minimum": 1,
      "title": "Record Version",
      "type": "integer"
    },
    "relations": {
      "default": [],
      "items": {
        "$ref": "#/$defs/Relation"
      },
      "title": "Relations",
      "type": "array"
    },
    "repository": {
      "default": "shared",
      "enum": [
        "vop_poc_nz",
        "voiage",
        "shared"
      ],
      "title": "Repository",
      "type": "string"
    },
    "requirement_ids": {
      "default": [],
      "items": {
        "type": "string"
      },
      "title": "Requirement Ids",
      "type": "array"
    },
    "schema_version": {
      "const": "1.0.0",
      "default": "1.0.0",
      "title": "Schema Version",
      "type": "string"
    },
    "status": {
      "enum": [
        "planned",
        "linked",
        "closed",
        "blocked"
      ],
      "title": "Status",
      "type": "string"
    },
    "summary": {
      "minLength": 1,
      "title": "Summary",
      "type": "string"
    },
    "tags": {
      "default": [],
      "items": {
        "type": "string"
      },
      "title": "Tags",
      "type": "array"
    },
    "target_record_ids": {
      "items": {
        "type": "string"
      },
      "minItems": 1,
      "title": "Target Record Ids",
      "type": "array"
    },
    "title": {
      "minLength": 1,
      "title": "Title",
      "type": "string"
    },
    "track_ids": {
      "default": [],
      "items": {
        "type": "string"
      },
      "title": "Track Ids",
      "type": "array"
    },
    "updated_at": {
      "anyOf": [
        {
          "format": "date-time",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Updated At"
    },
    "visibility": {
      "default": "public",
      "enum": [
        "public",
        "repository",
        "local_private"
      ],
      "title": "Visibility",
      "type": "string"
    }
  },
  "required": [
    "id",
    "title",
    "summary",
    "status",
    "target_record_ids",
    "github_repository"
  ],
  "title": "IssueLink",
  "type": "object"
}
