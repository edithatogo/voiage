{
  "$defs": {
    "Relation": {
      "additionalProperties": false,
      "description": "Typed edge between governance records.",
      "properties": {
        "relation": {
          "enum": [
            "informs",
            "depends_on",
            "blocks",
            "mitigates",
            "mitigated_by",
            "resolved_by",
            "supersedes",
            "implements",
            "supports",
            "challenges"
          ],
          "title": "Relation",
          "type": "string"
        },
        "target_id": {
          "pattern": "^(CON|ASM|RSK|DEC|EVR|ISL)-(VOP|VOI|SHR)-[0-9]{4}$",
          "title": "Target Id",
          "type": "string"
        }
      },
      "required": [
        "relation",
        "target_id"
      ],
      "title": "Relation",
      "type": "object"
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "A provenance-bearing reference that supports or challenges a record.",
  "properties": {
    "challenges": {
      "default": [],
      "items": {
        "type": "string"
      },
      "title": "Challenges",
      "type": "array"
    },
    "claim_ids": {
      "default": [],
      "items": {
        "type": "string"
      },
      "title": "Claim Ids",
      "type": "array"
    },
    "created_at": {
      "anyOf": [
        {
          "format": "date-time",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Created At"
    },
    "evidence_kind": {
      "enum": [
        "source",
        "derivation",
        "test",
        "benchmark",
        "run",
        "artifact",
        "review",
        "external_verification"
      ],
      "title": "Evidence Kind",
      "type": "string"
    },
    "evidence_reference_ids": {
      "default": [],
      "items": {
        "type": "string"
      },
      "title": "Evidence Reference Ids",
      "type": "array"
    },
    "gate": {
      "default": "local",
      "enum": [
        "none",
        "local",
        "external",
        "human",
        "credential",
        "hardware",
        "publication"
      ],
      "title": "Gate",
      "type": "string"
    },
    "git_commit": {
      "anyOf": [
        {
          "pattern": "^[0-9a-f]{40}$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Git Commit"
    },
    "id": {
      "title": "Id",
      "type": "string"
    },
    "issue_link_ids": {
      "default": [],
      "items": {
        "type": "string"
      },
      "title": "Issue Link Ids",
      "type": "array"
    },
    "locator": {
      "minLength": 1,
      "title": "Locator",
      "type": "string"
    },
    "locator_kind": {
      "enum": [
        "local_path",
        "url",
        "doi",
        "github_run",
        "commit",
        "pull_request",
        "issue",
        "release"
      ],
      "title": "Locator Kind",
      "type": "string"
    },
    "moscow": {
      "default": "should",
      "enum": [
        "must",
        "should",
        "could",
        "wont_now"
      ],
      "title": "Moscow",
      "type": "string"
    },
    "observed_at": {
      "format": "date-time",
      "title": "Observed At",
      "type": "string"
    },
    "owner_role": {
      "default": "maintainer",
      "title": "Owner Role",
      "type": "string"
    },
    "priority": {
      "default": "P2",
      "enum": [
        "P0",
        "P1",
        "P2",
        "P3"
      ],
      "title": "Priority",
      "type": "string"
    },
    "record_type": {
      "const": "evidence_reference",
      "default": "evidence_reference",
      "title": "Record Type",
      "type": "string"
    },
    "record_version": {
      "default": 1,
      "minimum": 1,
      "title": "Record Version",
      "type": "integer"
    },
    "relations": {
      "default": [],
      "items": {
        "$ref": "#/$defs/Relation"
      },
      "title": "Relations",
      "type": "array"
    },
    "repository": {
      "default": "shared",
      "enum": [
        "vop_poc_nz",
        "voiage",
        "shared"
      ],
      "title": "Repository",
      "type": "string"
    },
    "requirement_ids": {
      "default": [],
      "items": {
        "type": "string"
      },
      "title": "Requirement Ids",
      "type": "array"
    },
    "schema_version": {
      "const": "1.0.0",
      "default": "1.0.0",
      "title": "Schema Version",
      "type": "string"
    },
    "sha256": {
      "anyOf": [
        {
          "pattern": "^[0-9a-f]{64}$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Sha256"
    },
    "status": {
      "enum": [
        "unverified",
        "verified",
        "failed",
        "blocked",
        "superseded"
      ],
      "title": "Status",
      "type": "string"
    },
    "summary": {
      "minLength": 1,
      "title": "Summary",
      "type": "string"
    },
    "supports": {
      "default": [],
      "items": {
        "type": "string"
      },
      "title": "Supports",
      "type": "array"
    },
    "tags": {
      "default": [],
      "items": {
        "type": "string"
      },
      "title": "Tags",
      "type": "array"
    },
    "title": {
      "minLength": 1,
      "title": "Title",
      "type": "string"
    },
    "track_ids": {
      "default": [],
      "items": {
        "type": "string"
      },
      "title": "Track Ids",
      "type": "array"
    },
    "updated_at": {
      "anyOf": [
        {
          "format": "date-time",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Updated At"
    },
    "visibility": {
      "default": "public",
      "enum": [
        "public",
        "repository",
        "local_private"
      ],
      "title": "Visibility",
      "type": "string"
    }
  },
  "required": [
    "id",
    "title",
    "summary",
    "status",
    "evidence_kind",
    "locator_kind",
    "locator",
    "observed_at"
  ],
  "title": "EvidenceReference",
  "type": "object"
}
