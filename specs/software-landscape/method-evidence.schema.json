{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://voiage.dev/schemas/software-landscape/method-evidence-1.0.0.json",
  "title": "VOIAGE method evidence registry",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "reviewed_on", "sources", "coverage"],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "reviewed_on": {"type": "string", "format": "date"},
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "title", "kind", "url", "verification"],
        "properties": {
          "id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$"},
          "title": {"type": "string", "minLength": 1},
          "kind": {"enum": ["primary-paper", "guideline", "package-documentation", "repository-contract"]},
          "url": {"type": "string", "format": "uri"},
          "verification": {"enum": ["primary-verified", "repository-verified"]}
        }
      }
    },
    "coverage": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["family", "method_ids", "source_ids", "review_state", "note"],
        "properties": {
          "family": {"type": "string", "minLength": 1},
          "method_ids": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string"}},
          "source_ids": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string"}},
          "review_state": {"enum": ["primary-verified", "contract-verified", "triage-required"]},
          "note": {"type": "string", "minLength": 1}
        }
      }
    }
  }
}
