{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://voiage.dev/schemas/software-landscape/method-evidence-1.1.0.json",
  "title": "VOIAGE method evidence registry",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "reviewed_on", "review_due", "sources", "coverage"],
  "properties": {
    "schema_version": {"const": "1.1.0"},
    "reviewed_on": {"type": "string", "format": "date"},
    "review_due": {"type": "string", "format": "date"},
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "title", "kind", "url", "verification", "identifier"],
        "properties": {
          "id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$"},
          "title": {"type": "string", "minLength": 1},
          "kind": {
            "enum": [
              "primary-paper",
              "review-paper",
              "guideline",
              "package-documentation",
              "repository-contract"
            ]
          },
          "url": {"type": "string", "format": "uri"},
          "verification": {"enum": ["primary-verified", "repository-verified"]},
          "identifier": {"type": "string", "minLength": 1}
        }
      }
    },
    "coverage": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "method_id",
          "family",
          "source_ids",
          "review_state",
          "disposition",
          "decision_boundary",
          "required_decision_fields",
          "promotion_gate",
          "note"
        ],
        "properties": {
          "method_id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$"},
          "family": {"type": "string", "minLength": 1},
          "source_ids": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string"}},
          "review_state": {"enum": ["primary-verified", "contract-verified", "triage-required"]},
          "disposition": {
            "enum": [
              "canonical-estimand",
              "canonical-estimator",
              "supported-workflow",
              "supported-visualization",
              "related-analysis",
              "application-contract",
              "excluded-alias",
              "excluded-out-of-scope"
            ]
          },
          "decision_boundary": {
            "enum": [
              "requires-decision-problem-v2",
              "derived-decision-output",
              "information-theoretic-only",
              "repository-defined-perspective-contract",
              "not-voi"
            ]
          },
          "required_decision_fields": {
            "type": "array",
            "uniqueItems": true,
            "items": {
              "enum": [
                "alternatives",
                "uncertainty",
                "information_actions",
                "objective",
                "perspectives",
                "population",
                "time_horizon",
                "provenance"
              ]
            }
          },
          "promotion_gate": {
            "enum": [
              "none",
              "primary-literature-review",
              "independent-replication",
              "method-contract-and-fixtures",
              "external-scientific-review"
            ]
          },
          "note": {"type": "string", "minLength": 1}
        }
      }
    }
  }
}
