{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://voiage.dev/specs/software-landscape/schema.json",
  "title": "VOIAGE software landscape registry",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "searched_on",
    "review_due",
    "scope",
    "searches",
    "tools"
  ],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "searched_on": {"type": "string", "format": "date"},
    "review_due": {"type": "string", "format": "date"},
    "scope": {"type": "string", "minLength": 20},
    "searches": {
      "type": "array",
      "minItems": 9,
      "items": {"$ref": "#/$defs/search"}
    },
    "tools": {
      "type": "array",
      "minItems": 15,
      "items": {"$ref": "#/$defs/tool"}
    }
  },
  "$defs": {
    "url": {"type": "string", "pattern": "^https://"},
    "search": {
      "type": "object",
      "additionalProperties": false,
      "required": ["channel", "query", "source_url", "result"],
      "properties": {
        "channel": {"type": "string", "minLength": 1},
        "query": {"type": "string", "minLength": 3},
        "source_url": {"$ref": "#/$defs/url"},
        "result": {
          "enum": ["candidates-found", "no-direct-package-found"]
        },
        "notes": {"type": "string"}
      }
    },
    "feature": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "label",
        "kind",
        "method_ids",
        "parity_state",
        "voiage_evidence",
        "evidence"
      ],
      "properties": {
        "id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$"},
        "label": {"type": "string", "minLength": 2},
        "kind": {
          "enum": [
            "estimand",
            "estimator",
            "workflow",
            "visualization",
            "adapter",
            "application",
            "related-analysis"
          ]
        },
        "method_ids": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$"}
        },
        "parity_state": {
          "enum": [
            "native",
            "equivalent",
            "adapter",
            "planned",
            "excluded",
            "not-reproducible"
          ]
        },
        "voiage_evidence": {"type": "string"},
        "evidence": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/url"}
        },
        "notes": {"type": "string"}
      }
    },
    "tool": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "name",
        "ecosystem",
        "scope",
        "tool_kind",
        "maintenance",
        "license",
        "version",
        "release_date",
        "repository",
        "registry",
        "authoritative_sources",
        "features",
        "runtime_dependency"
      ],
      "properties": {
        "id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$"},
        "name": {"type": "string", "minLength": 1},
        "ecosystem": {
          "enum": ["r", "python", "rust", "julia", "mojo", "web", "commercial"]
        },
        "scope": {"enum": ["external", "internal-reference"]},
        "tool_kind": {
          "enum": [
            "voi-library",
            "decision-analysis-library",
            "modeling-library",
            "experimental-design-library",
            "active-learning-library",
            "web-application",
            "commercial-application",
            "binding"
          ]
        },
        "maintenance": {
          "enum": ["maintained", "limited", "archived", "unknown"]
        },
        "license": {"type": "string", "minLength": 1},
        "version": {"type": "string", "minLength": 1},
        "release_date": {"type": "string"},
        "repository": {"type": "string"},
        "registry": {"type": "string"},
        "authoritative_sources": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/url"}
        },
        "features": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/feature"}
        },
        "runtime_dependency": {"const": false},
        "limitations": {"type": "string"}
      }
    }
  }
}
