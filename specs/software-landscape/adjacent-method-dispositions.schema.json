{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://voiage.dev/schemas/software-landscape/adjacent-method-dispositions-1.0.0.json",
  "title": "VOIAGE adjacent-method disposition registry",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "reviewed_on", "review_due", "records"],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "reviewed_on": {"type": "string", "format": "date"},
    "review_due": {"type": "string", "format": "date"},
    "records": {
      "type": "array",
      "minItems": 10,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "label",
          "classification",
          "disposition",
          "canonical_method_ids",
          "source_urls",
          "rationale"
        ],
        "properties": {
          "id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$"},
          "label": {"type": "string", "minLength": 2},
          "classification": {
            "enum": [
              "alias",
              "estimator-variant",
              "application",
              "information-order",
              "adjacent-decision-value",
              "strategic-information",
              "information-theoretic-estimand"
            ]
          },
          "disposition": {
            "enum": [
              "map-to-canonical",
              "add-to-canonical-registry",
              "retain-as-related-analysis",
              "retain-as-application",
              "exclude-from-voi-core"
            ]
          },
          "canonical_method_ids": {
            "type": "array",
            "uniqueItems": true,
            "items": {"type": "string"}
          },
          "source_urls": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {"type": "string", "format": "uri"}
          },
          "rationale": {"type": "string", "minLength": 30}
        }
      }
    }
  }
}
