{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":semanticCommits",
    ":semanticCommitTypeAll(chore)",
    ":dependencyDashboard",
    ":enableVulnerabilityAlerts",
    ":pinDigestsDisabled",
    "group:monorepos",
    "group:recommended"
  ],
  "enabledManagers": [
    "cargo",
    "docker-compose",
    "github-actions",
    "git-submodules",
    "npm",
    "pep621",
    "pixi",
    "pre-commit"
  ],
  "dependencyDashboard": true,
  "dependencyDashboardTitle": "Renovate dependency and security dashboard",
  "dependencyDashboardLabels": ["dependencies"],
  "dependencyDashboardOSVVulnerabilitySummary": "all",
  "dependencyDashboardReportAbandonment": true,
  "osvVulnerabilityAlerts": true,
  "abandonmentThreshold": "2 years",
  "schedule": ["every weekend"],
  "prCreation": "not-pending",
  "internalChecksFilter": "strict",
  "minimumReleaseAge": "7 days",
  "minimumReleaseAgeBehaviour": "timestamp-required",
  "rebaseWhen": "behind-base-branch",
  "platformAutomerge": true,
  "automergeType": "pr",
  "statusCheckWhen": {
    "artifactError": "always",
    "configValidation": "always",
    "minimumReleaseAge": "always"
  },
  "packageRules": [
    {
      "description": "Automerge ordinary non-major updates only after stability and required checks",
      "matchManagers": ["cargo", "npm", "pep621"],
      "matchUpdateTypes": ["minor", "patch"],
      "automerge": true,
      "groupName": "non-major dependencies",
      "groupSlug": "non-major-dependencies"
    },
    {
      "description": "Keep GitHub Actions immutable and reviewed",
      "matchManagers": ["github-actions"],
      "pinDigests": true,
      "automerge": false,
      "groupName": "github actions",
      "addLabels": ["github-actions", "security"]
    },
    {
      "description": "Pin container image digests and require supply-chain review",
      "matchManagers": ["docker-compose"],
      "pinDigests": true,
      "automerge": false,
      "addLabels": ["supply-chain"]
    },
    {
      "description": "Environment and executable hook updates require review",
      "matchManagers": ["pixi", "pre-commit"],
      "automerge": false,
      "addLabels": ["quality-tooling", "supply-chain"]
    },
    {
      "description": "Python runtime upgrades require an explicit compatibility track",
      "matchPackageNames": ["python"],
      "enabled": false
    },
    {
      "description": "Numerical, inference and interchange dependencies always require review",
      "matchPackageNames": [
        "/^(jax|jaxlib|numpy|numpyro|pyarrow|polars|scipy|scikit-learn|xarray)$/"
      ],
      "automerge": false,
      "addLabels": ["numerical-assurance"]
    },
    {
      "matchPackageNames": ["/^(pytest|hypothesis|coverage|pytest-.+)$/"],
      "groupName": "testing dependencies",
      "groupSlug": "testing",
      "automerge": false,
      "addLabels": ["quality-tooling"]
    },
    {
      "matchPackageNames": ["/^(ruff|ty|basedpyright)$/"],
      "groupName": "linting and type checking",
      "groupSlug": "linting",
      "automerge": false,
      "addLabels": ["quality-tooling"]
    },
    {
      "description": "Major and breaking updates require human review",
      "matchUpdateTypes": ["major"],
      "automerge": false,
      "dependencyDashboardApproval": true,
      "addLabels": ["breaking-change"]
    },
    {
      "description": "Submodule changes carry executable source and require review",
      "matchManagers": ["git-submodules"],
      "automerge": false,
      "addLabels": ["supply-chain"]
    },
    {
      "description": "Lock maintenance is reviewed and exercised by the complete matrix",
      "matchUpdateTypes": ["lockFileMaintenance"],
      "automerge": false,
      "addLabels": ["lockfile"]
    }
  ],
  "labels": ["dependencies"],
  "prConcurrentLimit": 6,
  "prHourlyLimit": 2,
  "rangeStrategy": "pin",
  "separateMajorMinor": true,
  "separateMultipleMajor": true,
  "timezone": "Etc/UTC",
  "lockFileMaintenance": {
    "enabled": true,
    "schedule": ["every weekend"]
  },
  "vulnerabilityAlerts": {
    "enabled": true,
    "vulnerabilityFixStrategy": "lowest",
    "automerge": false,
    "labels": ["dependencies", "security"],
    "addLabels": ["priority:security"],
    "schedule": ["at any time"]
  }
}
